{
  "expo": {
    "name": "PanchitaFit",
    "slug": "panchita-fit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0a1e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.panchitafit.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0a1e",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.panchitafit.app"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "PanchitaFit",
      "shortName": "PanchitaFit"
    }
  }
}